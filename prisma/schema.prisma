// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  TV
}

enum TitleStatus {
  WATCHED
  WATCHLIST
}

model Title {
  id            String      @id @default(cuid())
  userId        String?
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  releaseDate   DateTime?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  genres        String[]    @default([])
  voteAverage   Float?
  runtime       Int?
  status        TitleStatus
  rating        Float?
  currentSeason Int?
  currentEpisode Int?
  totalSeasons  Int?
  seasonEpisodeCounts Int[] @default([])
  topCast       Json?
  directors     Json?
  watchUrl      String?
  addedAt       DateTime    @default(now())
  watchedAt     DateTime?
  updatedAt     DateTime    @updatedAt

  @@unique([tmdbId, mediaType, userId])
  @@index([userId, status, releaseYear])
}

model UserSettings {
  userId           String   @id
  theme            String?
  watchedSortKey   String?
  watchlistSortKey String?
  region           String?
  updatedAt        DateTime @updatedAt
}

model Review {
  id        String    @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType MediaType
  rating    Float?
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tmdbId, mediaType, userId])
  @@index([tmdbId, mediaType])
  @@index([userId])
}

model Profile {
  userId      String   @id
  displayName String
  handle      String   @unique
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Follow {
  followerId  String // Clerk userId of the follower
  followingId String // Clerk userId of the user being followed
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  // followerId is the PK's leftmost column (covers "who I follow"); this covers "who follows X".
  @@index([followingId])
}

model ReviewLike {
  userId    String // Clerk userId of the liker
  reviewId  String // Review.id — not a DB FK (Review has no relations); likes are cleaned up on review delete
  createdAt DateTime @default(now())

  @@id([userId, reviewId])
  @@index([reviewId])
}

model Comment {
  id        String   @id @default(cuid())
  reviewId  String // Review.id — not a DB FK (Review has no relations); comments are cleaned up on review delete
  userId    String // Clerk userId of the commenter
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, createdAt])
  @@index([userId])
}

model Notification {
  id        String     @id @default(cuid())
  userId    String // recipient (Clerk userId)
  actorId   String // who triggered it (Clerk userId)
  type      String // FOLLOW | LIKE | COMMENT | SUGGESTION
  reviewId  String? // the review involved, for LIKE/COMMENT
  tmdbId    Int? // the title involved, for SUGGESTION
  mediaType MediaType? // the title's media type, for SUGGESTION
  read      Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([userId, createdAt])
}

// One user recommending a specific title to another (with an optional note). Distinct from the
// generic Notification (which is fire-and-forget); a suggestion persists in the recipient's inbox
// until they dismiss it. Metadata is snapshotted so it survives the sender deleting their title.
model Suggestion {
  id          String    @id @default(cuid())
  fromUserId  String // Clerk userId of the sender
  toUserId    String // Clerk userId of the recipient
  tmdbId      Int
  mediaType   MediaType
  title       String
  posterUrl   String?
  releaseYear Int?
  message     String? // optional note from the sender
  createdAt   DateTime  @default(now())
  dismissedAt DateTime? // set when the recipient dismisses it (kept for "already sent" checks)

  @@unique([fromUserId, toUserId, tmdbId, mediaType])
  @@index([toUserId, dismissedAt, createdAt])
}

model ProfileFavorite {
  userId      String // Clerk userId of the profile owner
  tmdbId      Int
  mediaType   MediaType
  // Title metadata is snapshotted at pin time (copied from the user's own Title row) so favorites
  // survive title deletion and don't need cross-user Title resolution to display.
  title       String
  posterUrl   String?
  releaseYear Int?
  createdAt   DateTime  @default(now())

  @@id([userId, tmdbId, mediaType])
  @@index([userId, createdAt])
}

// A user-created list/collection (e.g. "Movie night", "Best of 2026"). Owned by one user; visible
// to everyone (this is a friends-and-family app). Items are a separate model so a list can hold
// titles the owner hasn't added to their own library.
model List {
  id          String   @id @default(cuid())
  userId      String // Clerk userId of the owner
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, updatedAt])
}

model ListItem {
  id        String    @id @default(cuid())
  listId    String // List.id — not a DB FK; items are cleaned up on list delete
  tmdbId    Int
  mediaType MediaType
  // Metadata is snapshotted at add time (like ProfileFavorite) so items survive title deletion and
  // need no cross-user Title resolution to display.
  title       String
  posterUrl   String?
  releaseYear Int?
  note        String? // optional per-item note from the list owner
  position    Int       @default(0) // manual ordering within the list (ascending)
  createdAt   DateTime  @default(now())

  @@unique([listId, tmdbId, mediaType])
  @@index([listId, position])
}

// A record of something a user did, for the follow feed. Reviews are NOT recorded here (they're
// their own rich feed items); this captures the lighter-weight actions — watched, rated, added to
// watchlist, favorited, finished a season, created a list. Metadata is snapshotted for display.
model Activity {
  id          String     @id @default(cuid())
  userId      String // who did it (Clerk userId)
  type        String // WATCHED | RATED | WATCHLISTED | FAVORITED | FINISHED_SEASON | LIST_CREATED
  tmdbId      Int?
  mediaType   MediaType?
  title       String?
  posterUrl   String?
  releaseYear Int?
  rating      Float? // for WATCHED / RATED
  season      Int? // for FINISHED_SEASON
  listId      String? // for LIST_CREATED
  listName    String? // for LIST_CREATED
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
}

// A group "what should we watch?" poll. The host opens it; anyone adds candidate titles and votes
// (approval-style — you can back several); the host closes it to lock in the winner.
model MovieNight {
  id         String    @id @default(cuid())
  hostUserId String // Clerk userId of the creator/host
  name       String
  status     String    @default("OPEN") // OPEN | CLOSED
  createdAt  DateTime  @default(now())
  closedAt   DateTime?

  @@index([status, createdAt])
}

model MovieNightCandidate {
  id            String    @id @default(cuid())
  movieNightId  String // MovieNight.id — not a DB FK; cleaned up on movie-night delete
  tmdbId        Int
  mediaType     MediaType
  title         String
  posterUrl     String?
  releaseYear   Int?
  addedByUserId String
  createdAt     DateTime  @default(now())

  @@unique([movieNightId, tmdbId, mediaType])
  @@index([movieNightId])
}

model MovieNightVote {
  candidateId String // MovieNightCandidate.id — not a DB FK; cleaned up on candidate/movie-night delete
  userId      String // Clerk userId of the voter
  createdAt   DateTime @default(now())

  @@id([candidateId, userId])
  @@index([candidateId])
}

model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   Json
  fetchedAt DateTime @default(now())
}

// Shared fixed-window rate-limit counters. DB-backed (not in-memory) so the limit holds across
// serverless instances without sticky sessions. `key` encodes the subject + window start.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

model TrendingItem {
  id            String    @id @default(cuid())
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  voteAverage   Float?
  fetchedAt     DateTime  @default(now())

  @@unique([tmdbId, mediaType])
}
