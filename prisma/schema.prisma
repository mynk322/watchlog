// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  TV
}

enum TitleStatus {
  WATCHED
  WATCHLIST
}

model Title {
  id            String      @id @default(cuid())
  userId        String?
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  releaseDate   DateTime?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  genres        String[]    @default([])
  voteAverage   Float?
  runtime       Int?
  status        TitleStatus
  rating        Float?
  currentSeason Int?
  currentEpisode Int?
  totalSeasons  Int?
  seasonEpisodeCounts Int[] @default([])
  topCast       Json?
  directors     Json?
  watchUrl      String?
  addedAt       DateTime    @default(now())
  watchedAt     DateTime?
  updatedAt     DateTime    @updatedAt

  @@unique([tmdbId, mediaType, userId])
  @@index([userId, status, releaseYear])
}

model UserSettings {
  userId           String   @id
  theme            String?
  watchedSortKey   String?
  watchlistSortKey String?
  region           String?
  updatedAt        DateTime @updatedAt
}

model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   Json
  fetchedAt DateTime @default(now())
}

model TrendingItem {
  id            String    @id @default(cuid())
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  voteAverage   Float?
  fetchedAt     DateTime  @default(now())

  @@unique([tmdbId, mediaType])
}
