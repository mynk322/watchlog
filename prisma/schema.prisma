// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  TV
}

enum TitleStatus {
  WATCHED
  WATCHLIST
}

model Title {
  id            String      @id @default(cuid())
  userId        String?
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  releaseDate   DateTime?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  genres        String[]    @default([])
  voteAverage   Float?
  runtime       Int?
  status        TitleStatus
  rating        Float?
  currentSeason Int?
  currentEpisode Int?
  totalSeasons  Int?
  seasonEpisodeCounts Int[] @default([])
  topCast       Json?
  directors     Json?
  watchUrl      String?
  addedAt       DateTime    @default(now())
  watchedAt     DateTime?
  updatedAt     DateTime    @updatedAt

  @@unique([tmdbId, mediaType, userId])
  @@index([userId, status, releaseYear])
}

model UserSettings {
  userId           String   @id
  theme            String?
  watchedSortKey   String?
  watchlistSortKey String?
  region           String?
  updatedAt        DateTime @updatedAt
}

model Review {
  id        String    @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType MediaType
  rating    Float?
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tmdbId, mediaType, userId])
  @@index([tmdbId, mediaType])
  @@index([userId])
}

model Profile {
  userId      String   @id
  displayName String
  handle      String   @unique
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Follow {
  followerId  String // Clerk userId of the follower
  followingId String // Clerk userId of the user being followed
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  // followerId is the PK's leftmost column (covers "who I follow"); this covers "who follows X".
  @@index([followingId])
}

model ReviewLike {
  userId    String // Clerk userId of the liker
  reviewId  String // Review.id — not a DB FK (Review has no relations); likes are cleaned up on review delete
  createdAt DateTime @default(now())

  @@id([userId, reviewId])
  @@index([reviewId])
}

model Comment {
  id        String   @id @default(cuid())
  reviewId  String // Review.id — not a DB FK (Review has no relations); comments are cleaned up on review delete
  userId    String // Clerk userId of the commenter
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, createdAt])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient (Clerk userId)
  actorId   String // who triggered it (Clerk userId)
  type      String // FOLLOW | LIKE | COMMENT
  reviewId  String? // the review involved, for LIKE/COMMENT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ProfileFavorite {
  userId      String // Clerk userId of the profile owner
  tmdbId      Int
  mediaType   MediaType
  // Title metadata is snapshotted at pin time (copied from the user's own Title row) so favorites
  // survive title deletion and don't need cross-user Title resolution to display.
  title       String
  posterUrl   String?
  releaseYear Int?
  createdAt   DateTime  @default(now())

  @@id([userId, tmdbId, mediaType])
  @@index([userId, createdAt])
}

model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   Json
  fetchedAt DateTime @default(now())
}

model TrendingItem {
  id            String    @id @default(cuid())
  tmdbId        Int
  mediaType     MediaType
  title         String
  releaseYear   Int?
  posterUrl     String?
  backdropUrl   String?
  overview      String?
  voteAverage   Float?
  fetchedAt     DateTime  @default(now())

  @@unique([tmdbId, mediaType])
}
