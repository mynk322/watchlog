# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# TMDB API (https://www.themoviedb.org/settings/api) — use the "API Read Access Token" (v4 auth)
TMDB_API_KEY=""

# Random secret used to authorize the /api/cron/refresh and /api/admin/claim-legacy-titles endpoints
# (Vercel Cron sends this as a Bearer token)
CRON_SECRET=""

# Clerk (https://clerk.com) — email+password and email-OTP sign-in enabled, Google OAuth off for now.
#
# Use PRODUCTION keys (pk_live_… / sk_live_…) for any deployed/shared environment. Development
# keys (pk_test_… / sk_test_…) run on Clerk's dev instance, which uses short-lived sessions and a
# cross-domain "dev browser" handoff — so users get re-prompted for login/email-OTP every time they
# open a shared link. Persistent ("sticky") sessions require a production instance with your domain's
# DNS records verified (Clerk Dashboard → Production) and session lifetimes set under Dashboard →
# Sessions. The Clerk application name shown on the sign-in card is also set in the Dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Required for server-side auth.protect() redirects to use our themed pages instead of Clerk's hosted ones
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
